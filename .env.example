LIFE_OS_VAULT_PATH=/Users/tdc/worktable/vault
LIFE_OS_DATABASE_PATH=/Users/tdc/.local/share/life-os/life-os.db
LIFE_OS_BACKUP_PATH=/Users/tdc/.local/share/life-os/backups
LIFE_OS_DEFAULT_MODE=dry-run
LIFE_OS_TIMEZONE=America/New_York
# Copy this template to ~/.config/life-os/.env, never into the repository or vault.
# Then run: chmod 600 ~/.config/life-os/.env
LIFE_OS_GMAIL_ENABLED=false
LIFE_OS_GMAIL_ACCOUNT_ID=me
LIFE_OS_CALENDAR_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Optional override; `email auth` stores this in macOS Keychain instead.
# GMAIL_REFRESH_TOKEN=
# Local macOS Messages ingestion. Populate with `life-os message conversations`.
LIFE_OS_IMESSAGE_ENABLED=false
LIFE_OS_IMESSAGE_SELECTION_MODE=allowlist
LIFE_OS_IMESSAGE_CONVERSATION_IDS=
# Used only when selection mode is all_except.
LIFE_OS_IMESSAGE_BLACKLIST_CONVERSATION_IDS=

# TDLib user-client ingestion. Keep these values in the external mode-600 env file.
LIFE_OS_TELEGRAM_ENABLED=false
LIFE_OS_TELEGRAM_SOURCE_ID=primary
LIFE_OS_TELEGRAM_CHAT_IDS=
LIFE_OS_TELEGRAM_DATABASE_PATH=/Users/tdc/.local/share/life-os/tdlib
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_DATABASE_ENCRYPTION_KEY=
# Optional when libtdjson is not on the platform library search path.
# LIFE_OS_TDLIB_LIBRARY_PATH=/opt/homebrew/lib/libtdjson.dylib
