LIFE_OS_VAULT_PATH=/Users/tdc/worktable/vault
LIFE_OS_DATABASE_PATH=/Users/tdc/.local/share/life-os/life-os.db
LIFE_OS_BACKUP_PATH=/Users/tdc/.local/share/life-os/backups
LIFE_OS_DEFAULT_MODE=dry-run
LIFE_OS_TIMEZONE=America/New_York
# Copy this template to ~/.config/life-os/.env, never into the repository or vault.
# Then run: chmod 600 ~/.config/life-os/.env
LIFE_OS_GMAIL_ENABLED=false
LIFE_OS_GMAIL_ACCOUNT_ID=me
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Optional override; `email auth` stores this in macOS Keychain instead.
# GMAIL_REFRESH_TOKEN=
